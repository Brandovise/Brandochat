# Local demo stack env (generated from Supabase local by scripts/demo/bootstrap-local-demo.sh)

# Supabase local API (typically http://127.0.0.1:54321)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Optional AI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Backend runtime
PORT=3847
WA_AUTH_ROOT=/app/data/wa_sessions
WA_BACKUP_ENABLED=false
WA_BACKUP_BUCKET=wa-sessions
WA_BACKUP_ENCRYPTION_KEY=

# Frontend build args (must target same local Supabase)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key

# Optional convenience values for scripts
DEMO_EMAIL=demo@brandochat.local
DEMO_PASSWORD=DemoPass123!
